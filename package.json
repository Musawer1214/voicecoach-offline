{
  "name": "voicecoach-offline",
  "version": "0.2.0",
  "description": "Offline-first Windows voice volume coaching prototype.",
  "productName": "VoiceCoach Offline",
  "author": "VoiceCoach Offline contributors",
  "private": true,
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "npm-run-all -p dev:renderer dev:electron:watch dev:electron:run",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:electron:watch": "tsc -p tsconfig.node.json --watch --preserveWatchOutput",
    "dev:electron:run": "wait-on tcp:5173 dist/main/main.js dist/preload/preload.js && cross-env ELECTRON_RUN_AS_NODE= ELECTRON_NO_ATTACH_CONSOLE= VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.node.json && vite build",
    "package:dir": "npm run build && electron-builder --dir --win",
    "dist:portable": "npm run build && electron-builder --win portable",
    "test": "vitest run"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "cross-env": "^10.1.0",
    "electron-is-dev": "^3.0.1",
    "lucide-react": "^0.555.0",
    "npm-run-all": "^4.1.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "wait-on": "^9.0.3"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "electron": "^39.2.4",
    "electron-builder": "^26.0.12",
    "jsdom": "^27.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.14"
  },
  "build": {
    "appId": "com.voicecoach.offline",
    "productName": "VoiceCoach Offline",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
